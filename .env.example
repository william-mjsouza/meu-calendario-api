# Copie este arquivo para .env e preencha com os valores da SUA máquina
# O .env é ignorado pelo Git — nunca comite credenciais reais

DB_URL=jdbc:postgresql://localhost:5432/meu_calendario
DB_USERNAME=seu_usuario_do_postgres
DB_PASSWORD=sua_senha_do_postgres
# Segredo do JWT em Base64 (gere um novo para seu ambiente):
#   Linux/Mac:   openssl rand -base64 48
#   PowerShell:  [Convert]::ToBase64String((1..48 | %{ Get-Random -Max 256 }))
JWT_SECRET=troque_por_um_segredo_base64_de_pelo_menos_32_bytes
